# =========================
# Server
# =========================
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
LOG_FILE=logs/app.log
MAINTENANCE_MODE=false

# =========================
# Application URLs
# =========================
APP_BASE_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"
PASSWORD_RESET_URL="http://localhost:3000/auth/reset-password"
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173"

# =========================
# Auth / Session
# =========================
JWT_SECRET=change_me
JWT_EXPIRES_IN=1d
SESSION_COOKIE_NAME=karirkit_session

# =========================
# Database
# =========================
DATABASE_URL=""
DATABASE_HOST="localhost"
DATABASE_PORT=3306
DATABASE_NAME="karirkit"
DATABASE_USER="user"
DATABASE_PASSWORD="password"

# =========================
# Redis
# =========================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_DB=0

# =========================
# Google OAuth
# =========================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =========================
# Mail
# =========================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@karirkit.local"
MAIL_FROM_NAME="KarirKit"

# =========================
# OTP
# =========================
OTP_ENABLED=false
OTP_EXPIRES_IN=5m
OTP_RESEND_COOLDOWN=60s

# =========================
# Storage
# =========================
DOCUMENT_STORAGE_LIMIT_MAX_BYTES=1073741824

# =========================
# Downloads & PDF Conversion
# =========================
PDF_DOWNLOAD_ENABLED=true
PDF_COMPRESSION_ENABLED=false
GHOSTSCRIPT_COMMAND=gs
GHOSTSCRIPT_PDFSETTINGS=/screen
GHOSTSCRIPT_COLOR_RESOLUTION=96
GHOSTSCRIPT_JPEG_QUALITY=60
LIBREOFFICE_COMMAND=soffice

# =========================
# Midtrans
# =========================
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_NOTIFICATION_URL=https://api.karirkit.local/subscriptions/midtrans/notification
