{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prisma:generate": "prisma generate",
    "prebuild": "prisma generate",
    "build": "tsc",
    "predev": "prisma generate",
    "pretest": "prisma generate",
    "dev": "bun --watch src/server.ts",
    "dev:node": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "bun dist/server.js",
    "start:node": "node dist/server.js",
    "key:generate": "bun ./scripts/key-generate.js",
    "seed": "bun prisma/seed.ts",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:api:real": "cross-env RUN_REAL_API_TESTS=true jest --config jest.real.config.js --runInBand"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@aws-sdk/client-s3": "^3.1054.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.21",
    "debug": "^4.4.3",
    "docx-templates": "^4.15.0",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "express-winston": "^4.2.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "midtrans-client": "^1.4.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.9",
    "openai": "^6.42.0",
    "pdfkit": "^0.18.0",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "yamljs": "^0.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.13",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/midtrans-client": "^1.4.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.19",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  }
